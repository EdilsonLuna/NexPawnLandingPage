---
import { t } from '../i18n';
import type { Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const checkIcon = `<path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>`;
const crossIcon = `<path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`;

const plans = t(lang, 'pricing.plans') as {
  plan: string; currency: string; amount: string; period: string;
  desc: string; cta: string; ctaVariant: string; popular: boolean;
  features: { text: string; included: boolean }[];
}[];
---

<section class="section section--alt" id="precios" aria-labelledby="pricing-title">
  <div class="container">

    <header class="section__header">
      <span class="section__eyebrow">{t(lang, 'pricing.eyebrow')}</span>
      <h2 class="section__title" id="pricing-title">
        {t(lang, 'pricing.title')}
      </h2>
      <p class="section__subtitle">
        {t(lang, 'pricing.subtitle')}
      </p>
    </header>

    <div class="pricing__grid">
      {plans.map((plan) => (
        <div class={`pricing-card${plan.popular ? ' pricing-card--popular' : ''}`}>
          {plan.popular && (
            <div class="pricing-card__badge">
              <span class="badge badge--popular">{t(lang, 'pricing.popularBadge')}</span>
            </div>
          )}

          <div class="pricing-card__plan">{plan.plan}</div>

          <div class="pricing-card__price">
            <span class="pricing-card__currency">{plan.currency}</span>
            <span class="pricing-card__amount">{plan.amount}</span>
            <span class="pricing-card__period">{plan.period}</span>
          </div>

          <p class="pricing-card__desc">{plan.desc}</p>

          <ul class="pricing-card__features" aria-label={`${t(lang, 'pricing.featuresLabel')} ${plan.plan}`}>
            {plan.features.map((feature) => (
              <li class={`pricing-card__feature${!feature.included ? ' pricing-card__feature--off' : ''}`}>
                <span class={`pricing-card__feature-icon${!feature.included ? ' pricing-card__feature-icon--off' : ''}`} aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" set:html={feature.included ? checkIcon : crossIcon} />
                </span>
                <span>{feature.text}</span>
              </li>
            ))}
          </ul>

          <a href="https://livedemo.nexpawn.com" class={`btn ${plan.ctaVariant} w-full`} style="justify-content:center">
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Footnote -->
    <p class="text-center text-muted" style="margin-top:var(--space-8);font-size:var(--font-size-sm);">
      {t(lang, 'pricing.footnote')}
      <a href="https://livedemo.nexpawn.com" class="text-blue font-semibold" style="margin-left:4px;">{t(lang, 'pricing.footnoteCta')}</a>
    </p>

  </div>
</section>
