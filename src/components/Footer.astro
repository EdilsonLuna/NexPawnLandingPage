---
interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;

const currentYear = new Date().getFullYear();

const t = {
  es: {
    tagline: 'El software moderno para casas de empeño. Rápido, seguro y fácil de usar.',
    col1: 'Producto',
    col2: 'Empresa',
    col3: 'Soporte',
    copy: 'Todos los derechos reservados.',
    privacy: 'Privacidad',
    privacyHref: '/es/politica-de-privacidad',
    terms: 'Términos de uso',
    termsHref: '/es/terminos-de-uso',
    cookies: 'Cookies',
    links: {
      producto: [
        { label: 'Funcionalidades', href: '#funcionalidades' },
        { label: 'Precios', href: '#precios' },
        { label: 'Demo gratuita', href: '#demo' },
        { label: 'Novedades', href: '#' },
      ],
      empresa: [
        { label: 'Sobre NexPawn', href: '#' },
        { label: 'Blog', href: '#' },
        { label: 'Contacto', href: 'mailto:hola@nexpawn.com' },
        { label: 'Trabaja con nosotros', href: '#' },
      ],
      soporte: [
        { label: 'Centro de ayuda', href: '#' },
        { label: 'Documentación', href: '#' },
        { label: 'Soporte técnico', href: '#' },
        { label: 'Estado del sistema', href: '#' },
      ],
    },
  },
  en: {
    tagline: 'Modern pawn shop software. Fast, secure and easy to use.',
    col1: 'Product',
    col2: 'Company',
    col3: 'Support',
    copy: 'All rights reserved.',
    privacy: 'Privacy',
    privacyHref: '/en/privacy-policy',
    terms: 'Terms of use',
    termsHref: '/en/terms-of-use',
    cookies: 'Cookies',
    links: {
      producto: [
        { label: 'Features', href: '#funcionalidades' },
        { label: 'Pricing', href: '#precios' },
        { label: 'Free demo', href: '#demo' },
        { label: "What's new", href: '#' },
      ],
      empresa: [
        { label: 'About NexPawn', href: '#' },
        { label: 'Blog', href: '#' },
        { label: 'Contact', href: 'mailto:hello@nexpawn.com' },
        { label: 'Work with us', href: '#' },
      ],
      soporte: [
        { label: 'Help center', href: '#' },
        { label: 'Documentation', href: '#' },
        { label: 'Technical support', href: '#' },
        { label: 'System status', href: '#' },
      ],
    },
  },
};

const copy = t[lang];
---

<footer class="footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="visually-hidden">Footer</h2>

  <div class="container">
    <div class="footer__grid">

      <!-- Brand column -->
      <div>
        <a href="/" class="footer__logo" aria-label="NexPawn inicio">
          <span class="footer__logo-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor"/>
              <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          Nex<span class="footer__logo-accent">Pawn</span>
        </a>
        <p class="footer__tagline">
          {copy.tagline}
        </p>
      </div>

      <!-- Product links -->
      <div>
        <p class="footer__col-title">{copy.col1}</p>
        <ul class="footer__links">
          {copy.links.producto.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <p class="footer__col-title">{copy.col2}</p>
        <ul class="footer__links">
          {copy.links.empresa.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support links -->
      <div>
        <p class="footer__col-title">{copy.col3}</p>
        <ul class="footer__links">
          {copy.links.soporte.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {currentYear} NexPawn. {copy.copy}
      </p>
      <nav class="footer__bottom-links" aria-label="Legal">
        <a href={copy.privacyHref} class="footer__bottom-link">{copy.privacy}</a>
        <a href={copy.termsHref} class="footer__bottom-link">{copy.terms}</a>
        <a href="#" class="footer__bottom-link">{copy.cookies}</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
