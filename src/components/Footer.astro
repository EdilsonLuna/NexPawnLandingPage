---
import { t } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const currentYear = new Date().getFullYear();

const productLinks = t(lang, 'footer.productLinks') as { label: string; href: string }[];
const companyLinks = t(lang, 'footer.companyLinks') as { label: string; href: string }[];
const supportLinks = t(lang, 'footer.supportLinks') as { label: string; href: string }[];
---

<footer class="footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="visually-hidden">Footer</h2>

  <div class="container">
    <div class="footer__grid">

      <!-- Brand column -->
      <div>
        <a href={`/${lang}/`} class="footer__logo" aria-label="NexPawn">
          <span class="footer__logo-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor"/>
              <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          Nex<span class="footer__logo-accent">Pawn</span>
        </a>
        <p class="footer__tagline">
          {t(lang, 'footer.tagline')}
        </p>
      </div>

      <!-- Product links -->
      <div>
        <p class="footer__col-title">{t(lang, 'footer.col1')}</p>
        <ul class="footer__links">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <p class="footer__col-title">{t(lang, 'footer.col2')}</p>
        <ul class="footer__links">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support links -->
      <div>
        <p class="footer__col-title">{t(lang, 'footer.col3')}</p>
        <ul class="footer__links">
          {supportLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {currentYear} NexPawn. {t(lang, 'footer.copy')}
      </p>
      <nav class="footer__bottom-links" aria-label="Legal">
        <a href={`/${lang}/privacy-policy`} class="footer__bottom-link">{t(lang, 'footer.privacy')}</a>
        <a href={`/${lang}/terms-of-use`} class="footer__bottom-link">{t(lang, 'footer.terms')}</a>
        <a
          href={lang === 'es' ? '/es/politica-reembolso' : `/${lang}/refund-policy`}
          class="footer__bottom-link"
        >
          {t(lang, 'footer.refund')}
        </a>
        <a href="#" class="footer__bottom-link">{t(lang, 'footer.cookies')}</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
